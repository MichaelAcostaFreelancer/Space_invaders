{
  "version": 2,
  "builds": [
    {
      "src": "api/index.rb",
      "use": "@vercel/ruby"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/api/index.rb"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|gif|ico|svg|mp3|wav|ogg|woff|woff2|ttf))",
      "dest": "/public/$1"
    },
    {
      "src": "/(css|js|images|sounds|assets|fonts)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.rb"
    }
  ]
}