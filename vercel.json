{
  "version": 2,
  "builds": [
    { "src": "api/index.rb", "use": "@vercel/ruby" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/api/index.rb"
    },
    {
      "src": "/",
      "dest": "/api/index.rb"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}