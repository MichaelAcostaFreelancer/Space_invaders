<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
    <meta name="description" content="Space Invaders Remastered en Ruby, Sinatra y Canvas">
    <title>SPACE INVADERS</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <div id="app">
      <div id="gameShell">
        <canvas id="gameCanvas" width="480" height="720" aria-label="Canvas del juego Space Invaders"></canvas>
        <div class="touch-controls" id="touchControls" aria-label="Controles táctiles">
          <div class="touch-group touch-group-left">
            <button id="leftBtn" class="touch-btn" data-control="left" type="button">◀</button>
            <button id="rightBtn" class="touch-btn" data-control="right" type="button">▶</button>
          </div>
          <div class="touch-group touch-group-right">
            <button id="shootBtn" class="touch-btn accent" data-control="shoot" type="button">DISPARAR</button>
          </div>
        </div>
        <div id="overlay" class="overlay visible">
          <div class="overlay-card">
            <p class="eyebrow">Campaña clásica</p>
            <h2>SPACE INVADERS REMASTERED</h2>
            <p class="overlay-copy">Una remasterización fiel al clásico, con campaña de 10 niveles, power-ups y una experiencia pulida para móvil y escritorio.</p>
            <div class="overlay-actions">
              <button class="primary-btn" data-action="start" type="button">JUGAR</button>
              <button class="secondary-btn" data-action="instructions" type="button">INSTRUCCIONES</button>
              <button class="secondary-btn" data-action="credits" type="button">CRÉDITOS</button>
            </div>
          </div>
        </div>
        <div id="orientationOverlay" class="orientation-overlay" aria-live="polite">
          <div class="orientation-card">
            <div class="phone-anim"></div>
            <h2>Gira tu dispositivo</h2>
            <p>Mantén el móvil en vertical para jugar cómodamente.</p>
          </div>
        </div>
      </div>

      <aside id="uiPanel">
        <div class="uiPanelInner">
          <div class="topbar">
            <p class="eyebrow">Arcade retro</p>
            <h1>SPACE INVADERS</h1>
          </div>

          <div class="status-grid">
            <div class="status-item"><span>Puntuación</span><strong id="scoreValue">0</strong></div>
            <div class="status-item"><span>Vidas</span><strong id="livesValue">3</strong></div>
            <div class="status-item"><span>Nivel</span><strong id="levelValue">1</strong></div>
            <div class="status-item"><span>Récord</span><strong id="bestValue">0</strong></div>
          </div>

          <div class="ui-actions">
            <label class="pill-btn range-pill" for="volumeSlider">
              <span>🔊</span>
              <input id="volumeSlider" type="range" min="0" max="100" value="50">
            </label>
            <button id="musicButton" class="pill-btn" type="button">Música: on</button>
            <button id="pauseButton" class="pill-btn" type="button">Pausar</button>
            <button id="restartButton" class="secondary-btn full-width" type="button">REINICIAR</button>
          </div>

          <div class="uiCopy">
            <h3>Resumen de misión</h3>
            <p>Defiende la Tierra de los invasores. Sobrevive, destruye oleadas y acumula la mejor puntuación.</p>
            <ul>
              <li>Teclado: ← → o A/D</li>
              <li>Espacio para disparar</li>
              <li>Móvil: botones táctiles</li>
            </ul>
          </div>

        </div>
      </aside>
    </div>

    <script src="/js/game.js"></script>
